{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "GlareMute",
  "version": "0.1.0",
  "identifier": "com.d0d1.glaremute",
  "build": {
    "beforeDevCommand": "pnpm --dir .. dev:web",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm --dir .. build:web",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "GlareMute",
        "width": 1320,
        "height": 860,
        "minWidth": 1120,
        "minHeight": 760,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
